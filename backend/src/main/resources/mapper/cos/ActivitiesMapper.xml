<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cc.mrbird.febs.cos.dao.ActivitiesMapper">

    <!-- 分页查询茶园活动信息 -->
    <select id="queryPage" resultType="java.util.LinkedHashMap">
        SELECT
        id,
        title,
        content,
        event_time,
        finish_time,
        publisher,
        created_at
        FROM
        activities
        WHERE
        1 = 1
        <if test="activities.title != null and activities.title != ''">
            AND title LIKE CONCAT('%',#{activities.title},'%')
        </if>
        <if test="activities.publisher != null and activities.publisher != ''">
            ANDpublisher LIKE CONCAT('%',#{activities.publisher},'%')
        </if>
        ORDER BY
        created_at DESC
    </select>
</mapper>
