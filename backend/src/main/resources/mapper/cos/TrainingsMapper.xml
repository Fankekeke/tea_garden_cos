<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cc.mrbird.febs.cos.dao.TrainingsMapper">

    <!-- 分页查询培训课程信息 -->
    <select id="queryPage" resultType="java.util.LinkedHashMap">
        SELECT
        id,
        title,
        video_url,
        description,
        created_at
        FROM
        trainings
        WHERE
        1 = 1
        <if test="trainings.title != null and trainings.title != ''">
            AND title LIKE CONCAT('%',#{trainings.title},'%')
        </if>
        ORDER BY
        created_at DESC
    </select>
</mapper>
